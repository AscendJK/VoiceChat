<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 背景色 -->
    <SolidColorBrush x:Key="WindowBackground" Color="#F0F2F5"/>
    <SolidColorBrush x:Key="CardBackground" Color="White"/>
    <SolidColorBrush x:Key="CardBackgroundAlt" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="HeaderBackground" Color="#1890FF"/>
    <SolidColorBrush x:Key="InputBackground" Color="White"/>

    <!-- 前景色 -->
    <SolidColorBrush x:Key="PrimaryText" Color="#333333"/>
    <SolidColorBrush x:Key="SecondaryText" Color="#595959"/>
    <SolidColorBrush x:Key="TertiaryText" Color="#8C8C8C"/>
    <SolidColorBrush x:Key="HeaderText" Color="White"/>
    <SolidColorBrush x:Key="SubHeaderText" Color="#E6F7FF"/>

    <!-- 边框 -->
    <SolidColorBrush x:Key="BorderBrush" Color="#E8E8E8"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#D9D9D9"/>
    <SolidColorBrush x:Key="FocusBorderBrush" Color="#1890FF"/>

    <!-- 按钮 -->
    <SolidColorBrush x:Key="PrimaryButtonBackground" Color="#1890FF"/>
    <SolidColorBrush x:Key="PrimaryButtonHover" Color="#40A9FF"/>
    <SolidColorBrush x:Key="PrimaryButtonPressed" Color="#096DD9"/>
    <SolidColorBrush x:Key="PrimaryButtonDisabled" Color="#D9D9D9"/>
    <SolidColorBrush x:Key="DangerButtonBackground" Color="#FF4D4F"/>
    <SolidColorBrush x:Key="DefaultButtonBackground" Color="White"/>
    <SolidColorBrush x:Key="DefaultButtonHover" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="DefaultButtonDisabled" Color="#F5F5F5"/>

    <!-- 特殊 -->
    <SolidColorBrush x:Key="SpeakingBrush" Color="#52C41A"/>
    <SolidColorBrush x:Key="SilentBrush" Color="#D9D9D9"/>
    <SolidColorBrush x:Key="SeparatorBrush" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="ProgressBarForeground" Color="#1890FF"/>

</ResourceDictionary>
