<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 背景色 -->
    <SolidColorBrush x:Key="WindowBackground" Color="#1A1A2E"/>
    <SolidColorBrush x:Key="CardBackground" Color="#16213E"/>
    <SolidColorBrush x:Key="CardBackgroundAlt" Color="#0F3460"/>
    <SolidColorBrush x:Key="HeaderBackground" Color="#0F3460"/>
    <SolidColorBrush x:Key="InputBackground" Color="#1A1A2E"/>

    <!-- 前景色 -->
    <SolidColorBrush x:Key="PrimaryText" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="SecondaryText" Color="#B0B0B0"/>
    <SolidColorBrush x:Key="TertiaryText" Color="#808080"/>
    <SolidColorBrush x:Key="HeaderText" Color="White"/>
    <SolidColorBrush x:Key="SubHeaderText" Color="#A0C4FF"/>

    <!-- 边框 -->
    <SolidColorBrush x:Key="BorderBrush" Color="#2A2A4A"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#3A3A5A"/>
    <SolidColorBrush x:Key="FocusBorderBrush" Color="#4A90D9"/>

    <!-- 按钮 -->
    <SolidColorBrush x:Key="PrimaryButtonBackground" Color="#4A90D9"/>
    <SolidColorBrush x:Key="PrimaryButtonHover" Color="#5AA0E9"/>
    <SolidColorBrush x:Key="PrimaryButtonPressed" Color="#3A80C9"/>
    <SolidColorBrush x:Key="PrimaryButtonDisabled" Color="#3A3A5A"/>
    <SolidColorBrush x:Key="DangerButtonBackground" Color="#DC3545"/>
    <SolidColorBrush x:Key="DefaultButtonBackground" Color="#2A2A4A"/>
    <SolidColorBrush x:Key="DefaultButtonHover" Color="#3A3A5A"/>
    <SolidColorBrush x:Key="DefaultButtonDisabled" Color="#1A1A2E"/>

    <!-- 特殊 -->
    <SolidColorBrush x:Key="SpeakingBrush" Color="#52C41A"/>
    <SolidColorBrush x:Key="SilentBrush" Color="#3A3A5A"/>
    <SolidColorBrush x:Key="SeparatorBrush" Color="#2A2A4A"/>
    <SolidColorBrush x:Key="ProgressBarForeground" Color="#4A90D9"/>

    <!-- ComboBox 样式 -->
    <Style TargetType="ComboBox">
        <Setter Property="Foreground" Value="#E0E0E0"/>
        <Setter Property="Background" Value="#1A1A2E"/>
        <Setter Property="BorderBrush" Value="#3A3A5A"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Foreground" Value="#E0E0E0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="6,4"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                        Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2A2A4A"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#0F3460"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ListBox 下拉项样式 -->
    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="#E0E0E0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#1A1A2E"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ListViewItem 样式 -->
    <Style TargetType="ListViewItem">
        <Setter Property="Foreground" Value="#E0E0E0"/>
    </Style>

    <!-- TextBox 样式 -->
    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="#E0E0E0"/>
        <Setter Property="Background" Value="#1A1A2E"/>
        <Setter Property="CaretBrush" Value="#E0E0E0"/>
    </Style>

    <!-- PasswordBox 样式 -->
    <Style TargetType="PasswordBox">
        <Setter Property="Foreground" Value="#E0E0E0"/>
        <Setter Property="Background" Value="#1A1A2E"/>
        <Setter Property="CaretBrush" Value="#E0E0E0"/>
    </Style>

    <!-- Slider 样式 -->
    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="#4A90D9"/>
    </Style>

    <!-- CheckBox 样式 -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="#E0E0E0"/>
    </Style>

    <!-- ToolTip 样式 -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="#16213E"/>
        <Setter Property="Foreground" Value="#E0E0E0"/>
        <Setter Property="BorderBrush" Value="#2A2A4A"/>
    </Style>

</ResourceDictionary>
