<Window x:Class="VoiceChat.App.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" Height="200" Width="400"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#1890FF"
        Topmost="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <Storyboard x:Key="FadeInStory">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
        </Storyboard>
    </Window.Resources>
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="🎙️ 局域网语音通话" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock Text="正在加载中..." FontSize="14" Foreground="#E6F7FF" HorizontalAlignment="Center" Margin="0,20,0,0"/>
            <ProgressBar IsIndeterminate="True" Width="200" Height="6" Margin="0,15,0,0" Foreground="White" Background="#40A9FF" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
