<Window x:Class="VoiceChat.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:VoiceChat.App"
        Title="局域网语音通话" Height="900" Width="1200" Icon="pack://application:,,,/icon.png"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackground}"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryButtonBackground}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource PrimaryButtonHover}"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="{DynamicResource PrimaryButtonPressed}"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="{DynamicResource PrimaryButtonDisabled}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{DynamicResource DangerButtonBackground}"/>
        </Style>
        <Style x:Key="DefaultButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource DefaultButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="BorderBrush" Value="{DynamicResource FocusBorderBrush}"/><Setter Property="Foreground" Value="{DynamicResource FocusBorderBrush}"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="{DynamicResource DefaultButtonDisabled}"/><Setter Property="Foreground" Value="{DynamicResource TertiaryText}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="QualityComboBox" TargetType="ComboBox">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DefaultButtonHover}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource FocusBorderBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                          Background="{TemplateBinding Background}" 
                                          BorderBrush="{TemplateBinding BorderBrush}" 
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Focusable="False" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <Grid>
                                    <TextBlock x:Name="ContentSite" IsHitTestVisible="False" 
                                               Text="{TemplateBinding SelectionBoxItem}"
                                               Foreground="{TemplateBinding Foreground}"
                                               Margin="6,3" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                    <Path x:Name="Arrow" Data="M 0 0 L 5 5 L 10 0" Stroke="{DynamicResource PrimaryText}" StrokeThickness="1.5"
                                          HorizontalAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                </Grid>
                            </ToggleButton>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" 
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" MaxHeight="{TemplateBinding MaxDropDownHeight}" 
                                      MinWidth="{TemplateBinding ActualWidth}" Background="{DynamicResource CardBackground}">
                                    <Border BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1">
                                        <ScrollViewer Margin="2" VerticalScrollBarVisibility="Auto">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6"/>
                    <Setter Property="Background" Value="{DynamicResource DefaultButtonDisabled}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TertiaryText}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBackground}" Padding="20,16" CornerRadius="8,8,0,0">
            <Grid>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🎙️ 局域网语音通话" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource HeaderText}"/>
                        <Button Content="🌙" FontSize="14" Margin="12,0,0,0" VerticalAlignment="Center"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Click="ThemeToggle_Click"/>
                    </StackPanel>
                    <TextBlock Text="{Binding RoomSession.ConnectionStatus}" Foreground="{DynamicResource SubHeaderText}" Margin="0,6,0,0" FontSize="13"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 音频设置面板 -->
        <Border Grid.Row="1" Background="{DynamicResource CardBackground}" Padding="16" Margin="0,12,0,0" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="🎤 麦克风设置" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="选择设备：" VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource PrimaryText}" Margin="0,0,10,0"/>
                        <ComboBox ItemsSource="{Binding AudioSettings.CaptureDevices}" SelectedItem="{Binding AudioSettings.SelectedCaptureDevice, Mode=TwoWay}" Width="300" Margin="0,0,10,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FriendlyName}" Foreground="{DynamicResource PrimaryText}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Content="🔄 刷新" Command="{Binding AudioSettings.RefreshDevicesCommand}" Style="{StaticResource DefaultButton}" Height="32"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
                        <TextBlock Text="输入音量：" VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource PrimaryText}" Margin="0,0,10,0"/>
                        <ProgressBar Value="{Binding AudioSettings.InputVolume}" Width="200" Height="20" Maximum="1" Foreground="{DynamicResource ProgressBarForeground}" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding AudioSettings.InputVolume, Converter={local:VolumeToPercentageConverter}}" FontSize="12" Foreground="{DynamicResource SecondaryText}" Width="40"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
                        <CheckBox IsChecked="{Binding AudioSettings.NoiseGateEnabled}" Content="🔇 噪声门限" FontSize="13" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="阈值：" FontSize="12" Foreground="{DynamicResource SecondaryText}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <Slider Value="{Binding AudioSettings.NoiseGateThreshold}" Minimum="0.001" Maximum="0.05" SmallChange="0.001" LargeChange="0.005" TickFrequency="0.001" IsSnapToTickEnabled="True" Width="120" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding AudioSettings.NoiseGateThreshold, StringFormat=F3}" FontSize="12" Foreground="{DynamicResource SecondaryText}" Width="50" Margin="4,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="🔊 扬声器设置" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="选择设备：" VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource PrimaryText}" Margin="0,0,10,0"/>
                        <ComboBox ItemsSource="{Binding AudioSettings.PlaybackDevices}" SelectedItem="{Binding AudioSettings.SelectedPlaybackDevice, Mode=TwoWay}" Width="300" Margin="0,0,10,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FriendlyName}" Foreground="{DynamicResource PrimaryText}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Content="🔄 刷新" Command="{Binding AudioSettings.RefreshPlaybackDevicesCommand}" Style="{StaticResource DefaultButton}" Height="32"/>
                    </StackPanel>
                    <Button Content="🔊 测试音频" Command="{Binding AudioSettings.LoopbackTestCommand}" Style="{StaticResource DefaultButton}" Height="36" Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：房间列表 -->
            <Border Grid.Column="0" Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="16">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="🔍 房间列表" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource PrimaryText}"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                        <Button Content="🔄 刷新" Command="{Binding RefreshRoomsCommand}" IsEnabled="{Binding CanRefreshRooms}" Style="{StaticResource DefaultButton}" Height="32" Margin="0,0,0,6"/>
                        <Button Content="✅ 加入房间" Command="{Binding JoinRoomCommand}" IsEnabled="{Binding CanJoinRoom}" Style="{StaticResource PrimaryButton}" Height="32"/>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding DiscoveredRooms}" SelectedItem="{Binding SelectedRoom}" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBackgroundAlt}" CornerRadius="8" Padding="14,12" Margin="0,0,0,10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="16" Foreground="{DynamicResource PrimaryText}"/>
                                            <TextBlock Text=" 🔒" FontSize="14" VerticalAlignment="Center" Visibility="{Binding HasPassword, Converter={local:BoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <TextBlock Text="{Binding HostName}" FontSize="14" Foreground="{DynamicResource SecondaryText}"/>
                                            <TextBlock Text=" • " FontSize="14" Foreground="{DynamicResource TertiaryText}"/>
                                            <TextBlock FontSize="14" Foreground="{DynamicResource SecondaryText}">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0}人在线"><Binding Path="MemberCount"/></MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem"><ContentPresenter/></ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- 右侧：当前房间 -->
            <Border Grid.Column="2" Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="16">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="👥 当前房间" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource PrimaryText}"/>
                    </StackPanel>

                    <!-- 底部控制区 -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                        <Separator Margin="0,0,0,12" Background="{DynamicResource SeparatorBrush}"/>
                        <!-- 创建房间区 -->
                        <Border Background="{DynamicResource CardBackgroundAlt}" CornerRadius="6" Padding="12" Margin="0,0,0,12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="创建新房间" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="房间名：" VerticalAlignment="Center" Grid.Column="0" FontSize="13" Foreground="{DynamicResource PrimaryText}"/>
                                    <TextBox Text="{Binding RoomSession.RoomName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBox}" Grid.Column="1" Margin="0,0,12,0"/>
                                    <TextBlock Text="昵称：" VerticalAlignment="Center" Grid.Column="2" FontSize="13" Foreground="{DynamicResource PrimaryText}"/>
                                    <TextBox Text="{Binding RoomSession.UserName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBox}" Grid.Column="3" Margin="0,0,12,0"/>
                                    <Button Content="创建房间" Command="{Binding RoomSession.CreateRoomCommand}" IsEnabled="{Binding RoomSession.CanCreateRoom}" Style="{StaticResource PrimaryButton}" Grid.Column="4"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="音质：" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource SecondaryText}" Margin="0,0,8,0"/>
                                    <ComboBox ItemsSource="{Binding AudioSettings.QualityOptions}" SelectedIndex="{Binding AudioSettings.SelectedQualityIndex}" IsEnabled="{Binding AudioSettings.CanChangeQuality}" Style="{StaticResource QualityComboBox}" Width="140" Height="28"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- 控制按钮 -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Visibility="{Binding RoomSession.IsHost, Converter={local:BoolToVisibilityConverter}}">
                            <Button Command="{Binding RoomSession.ToggleMuteSelfCommand}" IsEnabled="{Binding RoomSession.CanToggleMute}" Style="{StaticResource DefaultButton}" Width="140" Height="40" Margin="8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🎤" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding RoomSession.IsMuted, Converter={local:MuteButtonConverter}}" VerticalAlignment="Center" FontSize="14"/>
                                </StackPanel>
                            </Button>
                            <Button Content="🚪 解散房间" Command="{Binding RoomSession.DissolveRoomCommand}" IsEnabled="{Binding RoomSession.CanDissolveRoom}" Style="{StaticResource DangerButton}" Width="140" Height="40" Margin="8"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Visibility="{Binding RoomSession.IsHost, Converter={local:BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                            <Button Command="{Binding RoomSession.ToggleMuteSelfCommand}" IsEnabled="{Binding RoomSession.CanToggleMute}" Style="{StaticResource DefaultButton}" Width="140" Height="40" Margin="8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🎤" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding RoomSession.IsMuted, Converter={local:MuteButtonConverter}}" VerticalAlignment="Center" FontSize="14"/>
                                </StackPanel>
                            </Button>
                            <Button Content="🚪 离开房间" Command="{Binding RoomSession.LeaveRoomCommand}" IsEnabled="{Binding RoomSession.CanLeaveRoom}" Style="{StaticResource DangerButton}" Width="140" Height="40" Margin="8"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 成员列表 -->
                    <ListView ItemsSource="{Binding RoomSession.Members}" Margin="0,0,0,8" BorderThickness="0" Background="Transparent">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBackgroundAlt}" CornerRadius="6" Padding="14,10" Margin="0,0,0,6" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Width="180">
                                            <Ellipse Width="10" Height="10" Fill="{Binding IsSpeaking, Converter={local:BoolToSpeakingColorConverter}}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TertiaryText}" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="音量" FontSize="12" Foreground="{DynamicResource TertiaryText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Value="{Binding Volume, Mode=TwoWay}" Minimum="0" Maximum="2" Width="120" TickFrequency="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Volume, Converter={local:VolumeToPercentageConverter}}" FontSize="12" Foreground="{DynamicResource SecondaryText}" Margin="8,0,0,0" Width="35"/>
                                        </StackPanel>
                                        <Button Grid.Column="3" Content="踢出" Padding="10,4" Style="{StaticResource DangerButton}" FontSize="12"
                                                Command="{Binding DataContext.RoomSession.KickMemberCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                CommandParameter="{Binding Id}"
                                                Visibility="{Binding DataContext.RoomSession.IsHost, RelativeSource={RelativeSource AncestorType=ListView}, Converter={local:BoolToVisibilityConverter}}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem"><ContentPresenter/></ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </DockPanel>
            </Border>
        </Grid>

        <!-- 网络统计面板 -->
        <Border Grid.Row="3" Background="{DynamicResource CardBackgroundAlt}" Padding="14,8" CornerRadius="8" Margin="0,12,0,0"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Visibility="{Binding NetworkStats.IsStatsVisible, Converter={local:BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="延迟：" FontSize="12" Foreground="{DynamicResource TertiaryText}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding NetworkStats.Latency}" FontSize="12" Foreground="{DynamicResource SecondaryText}" Width="40" VerticalAlignment="Center"/>
                <TextBlock Text="ms" FontSize="12" Foreground="{DynamicResource TertiaryText}" VerticalAlignment="Center" Margin="0,0,16,0"/>

                <TextBlock Text="丢包：" FontSize="12" Foreground="{DynamicResource TertiaryText}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding NetworkStats.PacketLossRate, StringFormat=F1}" FontSize="12" Foreground="{DynamicResource SecondaryText}" Width="40" VerticalAlignment="Center"/>
                <TextBlock Text="%" FontSize="12" Foreground="{DynamicResource TertiaryText}" VerticalAlignment="Center" Margin="0,0,16,0"/>

                <TextBlock Text="发送：" FontSize="12" Foreground="{DynamicResource TertiaryText}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding NetworkStats.SentBytesPerSecond}" FontSize="12" Foreground="{DynamicResource SecondaryText}" Width="50" VerticalAlignment="Center"/>
                <TextBlock Text="B/s" FontSize="12" Foreground="{DynamicResource TertiaryText}" VerticalAlignment="Center" Margin="0,0,16,0"/>

                <TextBlock Text="接收：" FontSize="12" Foreground="{DynamicResource TertiaryText}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding NetworkStats.ReceivedBytesPerSecond}" FontSize="12" Foreground="{DynamicResource SecondaryText}" Width="50" VerticalAlignment="Center"/>
                <TextBlock Text="B/s" FontSize="12" Foreground="{DynamicResource TertiaryText}" VerticalAlignment="Center" Margin="0,0,16,0"/>

                <TextBlock Text="发包：" FontSize="12" Foreground="{DynamicResource TertiaryText}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding NetworkStats.SentPackets}" FontSize="12" Foreground="{DynamicResource SecondaryText}" Width="50" VerticalAlignment="Center"/>

                <TextBlock Text="收包：" FontSize="12" Foreground="{DynamicResource TertiaryText}" VerticalAlignment="Center" Margin="16,0,0,0"/>
                <TextBlock Text="{Binding NetworkStats.ReceivedPackets}" FontSize="12" Foreground="{DynamicResource SecondaryText}" Width="50" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 状态栏 -->
        <Border Grid.Row="4" Background="{DynamicResource CardBackground}" Padding="14,10" CornerRadius="0,0,8,8" Margin="0,4,0,0">
            <Grid>
                <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource SecondaryText}" FontSize="13"/>
                <TextBlock Text="💡 提示：创建房间后，同一局域网内的其他用户即可扫描加入" HorizontalAlignment="Right" Foreground="{DynamicResource TertiaryText}" FontSize="12"/>
            </Grid>
        </Border>
    </Grid>
</Window>
